# Official vLLM CPU OpenAI server image (pre-built on Docker Hub).
# Docs: https://docs.vllm.ai/en/stable/getting_started/installation/cpu.html#pre-built-images
#
# Tags: latest-arm64 (Apple Silicon, ARM kind nodes), latest-x86_64 (Intel/AMD / amd64 kind).
# Build (default ARM64):
#   docker build -f Dockerfile.worker -t llm-worker:latest .
# x86_64 / amd64 kind or Linux:
#   docker build -f Dockerfile.worker --build-arg VLLM_CPU_TAG=latest-x86_64 -t llm-worker:latest .
#
# Runtime args (model, host, port, dtype) are set in k8s/worker-deployment.yaml.
ARG VLLM_CPU_TAG=latest-arm64
FROM vllm/vllm-openai-cpu:${VLLM_CPU_TAG}
EXPOSE 8000
