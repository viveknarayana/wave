# OpenAI-compatible mock worker for kind/local when full vLLM image fails (e.g. CPU-only node).
# Build: docker build -f Dockerfile.worker-mock -t llm-worker-mock:latest .
FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir fastapi uvicorn
COPY mock_worker/app.py ./app.py
EXPOSE 8000
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]
